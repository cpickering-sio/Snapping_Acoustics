def plot_window_diagnostic(wav_path: Path, start_s: float = 0.0, duration_s: float = 10.0):
    """
    Plot 10s time series + red dots at detected snaps for visual validation.
    Uses original single-channel pressure processing (ignores vector channels).
    """
    import matplotlib.pyplot as plt
    
    # Use ORIGINAL single-channel loader
    volts, fs = load_wav_to_volts(wav_path)
    pressure_pa = volts_to_pressure_pa(volts)
    
    start_idx = int(start_s * fs)
    end_idx = int((start_s + duration_s) * fs)
    window = pressure_pa[start_idx:end_idx]
    
    # High-pass and detect
    window_hp = highpass_filter(window, fs)
    snaps = detect_snaps(window_hp, fs)
    
    # Color snaps by intensity (RL) for better visualization
    RLs_db = compute_snap_RLs(window_hp, snaps, fs)
